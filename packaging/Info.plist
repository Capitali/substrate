<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>Familiar</string>
  <key>CFBundleDisplayName</key><string>The Familiar</string>
  <key>CFBundleIdentifier</key><string>io.river.familiar</string>
  <!-- The marble (menu-bar presence) is the app's face and entry point; it launches the
       Glass and the familiar daemon, which live beside it in Contents/MacOS. -->
  <key>CFBundleExecutable</key><string>marble</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleIconFile</key><string>AppIcon</string>
  <key>CFBundleVersion</key><string>0.1.0</string>
  <key>CFBundleShortVersionString</key><string>0.1.0</string>
  <key>LSMinimumSystemVersion</key><string>12.0</string>
  <!-- Accessory app: present in the menu bar, absent from the Dock (matches the marble's
       NSApplication Accessory activation policy). -->
  <key>LSUIElement</key><true/>
  <!-- Why the app may use the camera. Shown in the system permission prompt and in
       System Settings. Honest about the gate: the familiar only watches when you allow it. -->
  <key>NSCameraUsageDescription</key>
  <string>The Familiar observes its surroundings through the camera only while you have opened the camera gate, to give it the visual awareness you asked it for.</string>
  <key>NSHumanReadableCopyright</key><string>© Ian Schlueter</string>
</dict>
</plist>
