# Substrate LLM keys — local secrets, NEVER committed.
#
# The factory does not read this file unless a HUMAN has opened the boundary
# (boundary.json: "allow_llm": true). Under the default-closed boundary the obedience
# guard refuses any LLM consult, so no key is ever read. See docs/boundaries.md.
#
# Setup (Phase 1):
#   mkdir -p substrate_data/llm
#   cp llm/call_llm.sh        substrate_data/llm/
#   cp llm/key.env.example    substrate_data/llm/key.env
#   # paste real keys below, then: chmod 600 substrate_data/llm/key.env
#   cp data/sample/boundary.phase-1.example.json substrate_data/boundary.json
#
# call_llm.sh sources key.env automatically. It matches *.env in .gitignore, so a
# real key.env can never be accidentally committed.

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
export GEMINI_API_KEY=""

# Cerebras — https://cloud.cerebras.ai
export CEREBRAS_API_KEY=""

# Optional shared fallback key:
# export SUBSTRATE_LLM_API_KEY=""

# Optional — failover order / model overrides:
# export SUBSTRATE_LLM_PROVIDER="gemini,cerebras"
# export GEMINI_MODEL="gemini-2.5-flash"
# export CEREBRAS_MODEL="gpt-oss-120b"
